<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistem Administrasi Proyek - Shanti Villages</title>
    <!-- Diubah ke Tailwind CSS v3 yang lebih stabil untuk HTML statis -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- FontAwesome for beautiful icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* Custom scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f5f9;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }

        /* Print Style matching Official Code FR/PRJ/004 */
        @media print {
            body * {
                visibility: hidden;
            }
            #printArea, #printArea * {
                visibility: visible;
            }
            #printArea {
                position: absolute;
                left: 0;
                top: 0;
                width: 100%;
                color: #000;
                background: #fff;
                font-family: 'Arial', sans-serif;
                font-size: 11pt;
            }
            .no-print {
                display: none !important;
            }
            table {
                border-collapse: collapse;
                width: 100%;
            }
            th, td {
                border: 1px solid #000 !important;
                padding: 6px !important;
                font-size: 10pt;
            }
            th {
                background-color: #f2f2f2 !important;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }
            .print-header {
                border: 2px solid #000;
                margin-bottom: 15px;
            }
            .print-title {
                font-size: 16pt;
                font-weight: bold;
                text-align: center;
                padding: 10px;
                border-bottom: 2px solid #000;
            }
            @page {
                size: A4;
                margin: 15mm 10mm;
            }
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 font-sans antialiased min-h-screen flex flex-col">

    <!-- TOP NAVBAR -->
    <header class="bg-indigo-900 text-white shadow-md no-print">
        <div class="container mx-auto px-4 py-3 flex justify-between items-center">
            <div class="flex items-center space-x-3">
                <div class="bg-amber-500 p-2 rounded-lg text-indigo-950 font-bold">
                    <i class="fa-solid fa-helmet-safety text-xl"></i>
                </div>
                <div>
                    <h1 class="text-lg font-bold tracking-wide">SHANTI VILLAGES</h1>
                    <p class="text-xs text-indigo-200">Sistem Administrasi Proyek Digital</p>
                </div>
            </div>
            <div class="text-sm text-indigo-100 flex items-center space-x-2">
                <i class="fa-solid fa-calendar-days text-amber-400"></i>
                <span id="current-date-display">Minggu, 12 Juli 2026</span>
            </div>
        </div>
    </header>

    <!-- MAIN INTERFACE CONTAINER -->
    <div class="container mx-auto px-4 py-6 flex-grow flex flex-col md:flex-row gap-6 no-print">
        
        <!-- SIDE NAVIGATION -->
        <aside class="w-full md:w-64 shrink-0">
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-4 sticky top-6 space-y-2">
                <p class="text-xs font-semibold text-slate-400 uppercase px-3 mb-2 tracking-wider">Menu Utama</p>
                
                <button onclick="switchTab('daily-report-tab')" id="btn-daily-report-tab" class="nav-btn w-full flex items-center space-x-3 px-4 py-3 rounded-lg text-sm font-medium transition-all bg-indigo-50 text-indigo-700 shadow-sm">
                    <i class="fa-solid fa-file-invoice text-base text-indigo-600"></i>
                    <span>Laporan Harian</span>
                </button>
                
                <button onclick="switchTab('purchase-order-tab')" id="btn-purchase-order-tab" class="nav-btn w-full flex items-center space-x-3 px-4 py-3 rounded-lg text-sm font-medium transition-all text-slate-600 hover:bg-slate-50 hover:text-slate-900">
                    <i class="fa-solid fa-cart-shopping text-base text-slate-400"></i>
                    <span>Purchase Order (PO)</span>
                </button>
                
                <button onclick="switchTab('documentation-tab')" id="btn-documentation-tab" class="nav-btn w-full flex items-center space-x-3 px-4 py-3 rounded-lg text-sm font-medium transition-all text-slate-600 hover:bg-slate-50 hover:text-slate-900">
                    <i class="fa-solid fa-camera text-base text-slate-400"></i>
                    <span>Dokumentasi Proyek</span>
                </button>

                <div class="pt-4 mt-4 border-t border-slate-100 bg-slate-50 p-3 rounded-lg">
                    <div class="flex items-center space-x-2 text-xs text-slate-500 mb-1">
                        <i class="fa-solid fa-circle-check text-emerald-500"></i>
                        <span class="font-medium">Status Server</span>
                    </div>
                    <p class="text-[11px] text-slate-400 leading-relaxed">Berjalan lokal via static HTML. Siap dideploy ke Vercel.</p>
                </div>
            </div>
        </aside>

        <!-- CONTENT AREA -->
        <main class="flex-grow">
            
            <!-- TAB 1: LAPORAN HARIAN -->
            <section id="daily-report-tab" class="tab-content bg-white rounded-xl shadow-sm border border-slate-200 p-6 space-y-6">
                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-slate-100 pb-4">
                    <div>
                        <h2 class="text-xl font-bold text-slate-900 flex items-center gap-2">
                            <i class="fa-solid fa-paste text-indigo-600"></i> Laporan Harian Konstruksi
                        </h2>
                        <p class="text-xs text-slate-500">Isi data lapangan hari ini untuk menghasilkan berkas resmi FR/PRJ/004 & format WhatsApp.</p>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        <button onclick="loadSampleDailyReport()" class="bg-slate-100 text-slate-700 hover:bg-slate-200 px-3 py-1.5 rounded-lg text-xs font-medium transition-colors flex items-center gap-1.5">
                            <i class="fa-solid fa-wand-magic-sparkles"></i> Gunakan Contoh Data
                        </button>
                    </div>
                </div>

                <!-- FORM INPUT LAPORAN HARIAN -->
                <form id="dailyReportForm" class="space-y-6">
                    <!-- Metadata Proyek -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div>
                            <label class="block text-xs font-semibold text-slate-600 uppercase mb-1">Nama Proyek</label>
                            <input type="text" id="rep-project" value="Shanti Villages-Balangan" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500">
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-slate-600 uppercase mb-1">Tanggal Update</label>
                            <input type="date" id="rep-date" value="2026-07-12" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500">
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-slate-600 uppercase mb-1">Kondisi Cuaca</label>
                            <select id="rep-weather" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500">
                                <option value="Cerah (Sunny)">Cerah (Sunny)</option>
                                <option value="Berawan (Cloudy)">Berawan (Cloudy)</option>
                                <option value="Hujan (Rainy)">Hujan (Rainy)</option>
                            </select>
                        </div>
                    </div>

                    <!-- Item Pekerjaan / List Update -->
                    <div class="space-y-3">
                        <h3 class="text-sm font-bold text-slate-800 border-l-4 border-amber-500 pl-2">Progress Pekerjaan Utama</h3>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-xs font-medium text-slate-500 mb-1">Pekerjaan Villa 13</label>
                                <textarea id="rep-villa13" rows="5" class="w-full bg-slate-50 border border-slate-200 rounded-lg p-3 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500" placeholder="Masukkan poin pekerjaan, gunakan baris baru untuk setiap poin"></textarea>
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-slate-500 mb-1">Pekerjaan Villa 15</label>
                                <textarea id="rep-villa15" rows="5" class="w-full bg-slate-50 border border-slate-200 rounded-lg p-3 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500" placeholder="Masukkan poin pekerjaan, gunakan baris baru untuk setiap poin"></textarea>
                            </div>
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-slate-500 mb-1">Update Pekerjaan Umum Lainnya</label>
                            <input type="text" id="rep-general" value="Update pekerjaan hari ini Juli 2026." class="w-full bg-slate-50 border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500">
                        </div>
                    </div>

                    <!-- Tenaga Kerja & Team Mandor -->
                    <div class="space-y-3">
                        <h3 class="text-sm font-bold text-slate-800 border-l-4 border-amber-500 pl-2">Manpower / Alokasi Tenaga Kerja</h3>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 bg-slate-50 p-4 rounded-xl border border-slate-100">
                            <div>
                                <label class="block text-xs font-medium text-slate-600 mb-1">Tim Sipil (Nama & Peran)</label>
                                <textarea id="rep-man-civil" rows="4" class="w-full bg-white border border-slate-200 rounded-lg p-2 text-xs focus:outline-none focus:ring-2 focus:ring-indigo-500/20" placeholder="Contoh:
Samsul (tukang)
Wahid (kuli)"></textarea>
                                <div class="grid grid-cols-2 gap-2 mt-2">
                                    <input type="number" id="count-tukang" placeholder="Jml Tukang" class="w-full bg-white border border-slate-200 rounded-md p-1.5 text-xs">
                                    <input type="number" id="count-kuli" placeholder="Jml Kuli" class="w-full bg-white border border-slate-200 rounded-md p-1.5 text-xs">
                                </div>
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-slate-600 mb-1">Tim Finishing Cat</label>
                                <textarea id="rep-man-paint" rows="4" class="w-full bg-white border border-slate-200 rounded-lg p-2 text-xs focus:outline-none focus:ring-2 focus:ring-indigo-500/20" placeholder="Contoh:
Agung
Suidi"></textarea>
                                <input type="number" id="count-paint" placeholder="Total Tim Cat" class="w-full bg-white border border-slate-200 rounded-md p-1.5 text-xs mt-2">
                            </div>
                            <div class="space-y-2">
                                <div>
                                    <label class="block text-xs font-medium text-slate-600 mb-1">Team AC (Orang)</label>
                                    <input type="number" id="count-ac" value="3" class="w-full bg-white border border-slate-200 rounded-lg p-2 text-xs">
                                </div>
                                <div>
                                    <label class="block text-xs font-medium text-slate-600 mb-1">Team Listrik (Orang)</label>
                                    <input type="number" id="count-elec" value="2" class="w-full bg-white border border-slate-200 rounded-lg p-2 text-xs">
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Alat Kerja & Material -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <h3 class="text-sm font-bold text-slate-800 border-l-4 border-amber-500 pl-2 mb-2">Alat Kerja Terpakai / Kondisi</h3>
                            <textarea id="rep-tools" rows="5" class="w-full bg-slate-50 border border-slate-200 rounded-lg p-3 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500" placeholder="Masukkan daftar alat kerja (pisahkan dengan koma atau baris baru)"></textarea>
                        </div>
                        <div>
                            <h3 class="text-sm font-bold text-slate-800 border-l-4 border-amber-500 pl-2 mb-2">Logistik Material Masuk / Digunakan</h3>
                            <textarea id="rep-materials" rows="5" class="w-full bg-slate-50 border border-slate-200 rounded-lg p-3 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500" placeholder="Masukkan daftar material (pisahkan dengan koma atau baris baru)"></textarea>
                        </div>
                    </div>

                    <!-- AKSI OUTPUT -->
                    <div class="flex flex-wrap gap-3 pt-2 justify-end border-t border-slate-100">
                        <button type="button" onclick="generateReportWA()" class="bg-emerald-600 text-white hover:bg-emerald-700 px-4 py-2.5 rounded-lg text-sm font-medium shadow-sm transition-colors flex items-center gap-2">
                            <i class="fa-brands fa-whatsapp text-lg"></i> Format ke WhatsApp
                        </button>
                        <button type="button" onclick="processPDFExport(false)" class="bg-indigo-600 text-white hover:bg-indigo-700 px-4 py-2.5 rounded-lg text-sm font-medium shadow-sm transition-colors flex items-center gap-2">
                            <i class="fa-solid fa-file-pdf"></i> Cetak / Simpan PDF (Indo)
                        </button>
                        <button type="button" onclick="processPDFExport(true)" class="bg-amber-500 text-indigo-950 hover:bg-amber-600 px-4 py-2.5 rounded-lg text-sm font-bold shadow-sm transition-colors flex items-center gap-2">
                            <i class="fa-solid fa-language"></i> Translate & Cetak PDF (EN)
                        </button>
                    </div>
                </form>
            </section>

            <!-- TAB 2: PURCHASE ORDER (PO) -->
            <section id="purchase-order-tab" class="tab-content hidden bg-white rounded-xl shadow-sm border border-slate-200 p-6 space-y-6">
                <div>
                    <h2 class="text-xl font-bold text-slate-900 flex items-center gap-2">
                        <i class="fa-solid fa-cart-shopping text-indigo-600"></i> Pengadaan Material & Alat (Purchase Order)
                    </h2>
                    <p class="text-xs text-slate-500">Buat permintaan PO logistik proyek, rekam otomatis ke dalam sistem, dan teruskan ke WhatsApp purchasing.</p>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                    <!-- Form Pengisian PO -->
                    <form id="poForm" class="lg:col-span-2 space-y-4 bg-slate-50 p-5 rounded-xl border border-slate-100">
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                            <div>
                                <label class="block text-xs font-semibold text-slate-600 mb-1">Nama Proyek</label>
                                <input type="text" id="po-project" value="Shanti Village" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 text-sm">
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-slate-600 mb-1">Tanggal Kebutuhan</label>
                                <input type="date" id="po-date" value="2026-07-12" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 text-sm">
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-slate-600 mb-1">Kode PO (Otomatis/Manual)</label>
                                <input type="text" id="po-code" value="PO02" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 text-sm font-mono font-bold text-indigo-700">
                            </div>
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-slate-600 mb-1">Judul / Pengadaan Berupa</label>
                            <input type="text" id="po-title" value="Pengadaan kertas A3" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 text-sm" placeholder="Contoh: Pembelian semen tigaroda">
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-slate-600 mb-1">Daftar Item Kebutuhan (Format: Nama Barang #Jumlah Satuan)</label>
                            <textarea id="po-items" rows="4" class="w-full bg-white border border-slate-200 rounded-lg p-3 text-sm focus:outline-none" placeholder="Kertas A3 70gsm #2 rim&#10;Semen Padang #50 sak"></textarea>
                            <p class="text-[11px] text-slate-400 mt-1">Gunakan karakter pagar (#) untuk memisahkan kuantitas barang agar tampilan rapi.</p>
                        </div>
                        <div class="flex gap-2 justify-end pt-2">
                            <button type="button" onclick="savePurchaseOrder()" class="bg-indigo-900 text-white hover:bg-indigo-950 px-4 py-2 rounded-lg text-xs font-medium transition-colors">
                                <i class="fa-solid fa-floppy-disk mr-1"></i> Simpan Ke Storage
                            </button>
                            <button type="button" onclick="generatePOWA()" class="bg-emerald-600 text-white hover:bg-emerald-700 px-4 py-2 rounded-lg text-xs font-medium transition-colors flex items-center gap-1.5">
                                <i class="fa-brands fa-whatsapp text-sm"></i> Kirim Format WA
                            </button>
                        </div>
                    </form>

                    <!-- Riwayat PO Terdaftar -->
                    <div class="space-y-3">
                        <h3 class="text-xs font-bold text-slate-500 uppercase tracking-wider">Log Riwayat PO (LocalStorage)</h3>
                        <div id="po-logs-list" class="space-y-2 max-h-80 overflow-y-auto pr-1">
                            <!-- PO list cards render here via JS -->
                            <div class="text-center py-6 text-xs text-slate-400 bg-slate-50 rounded-lg border border-dashed border-slate-200">
                                Belum ada riwayat PO tersimpan hari ini.
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- TAB 3: DOKUMENTASI PROYEK -->
            <section id="documentation-tab" class="tab-content hidden bg-white rounded-xl shadow-sm border border-slate-200 p-6 space-y-6">
                <div>
                    <h2 class="text-xl font-bold text-slate-900 flex items-center gap-2">
                        <i class="fa-solid fa-camera text-indigo-600"></i> Kamera Dokumentasi Lapangan Otomatis
                    </h2>
                    <p class="text-xs text-slate-500">Ambil foto progress proyek langsung dari lapangan. Sistem akan otomatis menyematkan watermark Waktu, Tanggal, dan Lokasi secara real-time.</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Sisi Kontrol Pengunggahan / Kamera -->
                    <div class="space-y-4 bg-slate-50 p-5 rounded-xl border border-slate-100 flex flex-col justify-between">
                        <div class="space-y-3">
                            <div>
                                <label class="block text-xs font-semibold text-slate-600 mb-1">Nama Lokasi / Area Detail Proyek</label>
                                <input type="text" id="doc-location-name" value="Villa 13 - Living Area & Decking" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 text-sm" placeholder="Contoh: Area Kolam Renang Villa 15">
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-slate-600 mb-1">Ambil Gambar / Upload Berkas</label>
                                <input type="file" id="doc-file-input" accept="image/*" capture="environment" onchange="processProjectPhoto(event)" class="w-full text-xs text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100 cursor-pointer">
                            </div>
                            <div class="pt-2">
                                <button type="button" onclick="requestGPSLocation()" class="w-full bg-slate-200 text-slate-700 hover:bg-slate-300 px-3 py-2 rounded-lg text-xs font-medium transition-colors flex items-center justify-center gap-1.5">
                                    <i class="fa-solid fa-location-crosshairs text-amber-600"></i> Sinkronisasi Koordinat GPS Otomatis
                                </button>
                                <p id="gps-status" class="text-[10px] text-center text-slate-500 mt-1">Koordinat belum dimuat (menggunakan waktu lokal perangkat)</p>
                            </div>
                        </div>

                        <div class="bg-amber-50 rounded-lg p-3 border border-amber-200 text-xs text-amber-800 space-y-1 mt-4">
                            <div class="font-bold flex items-center gap-1"><i class="fa-solid fa-cloud-arrow-up"></i> Catatan Integrasi Google Drive:</div>
                            <p class="leading-relaxed text-[11px]">Karena Vercel berjalan sebagai platform statis, nama file hasil olahan akan disesuaikan otomatis mengikuti pola regulasi manajemen proyek agar seragam saat anda unggah ke folder Google Drive perusahaan.</p>
                        </div>
                    </div>

                    <!-- Ruang Hasil Pengolahan Gambar / Watermark Canvas -->
                    <div class="flex flex-col items-center justify-center border-2 border-dashed border-slate-200 rounded-xl p-4 bg-slate-50 min-h-64 relative">
                        <p id="canvas-placeholder" class="text-xs text-slate-400 text-center py-12"><i class="fa-solid fa-image text-3xl block mb-2 text-slate-300"></i>Pratinjau foto beserta stamp otomatis akan muncul di sini setelah file dipilih.</p>
                        <canvas id="watermarkCanvas" class="max-w-full max-h-96 rounded-lg shadow-md hidden bg-white"></canvas>
                        
                        <div id="download-doc-area" class="w-full mt-4 hidden">
                            <div class="text-xs font-mono bg-slate-800 text-emerald-400 p-2 rounded-md mb-2 overflow-x-auto whitespace-nowrap" id="generated-filename-label">
                                Nama File: -
                            </div>
                            <button onclick="downloadStampedPhoto()" class="w-full bg-indigo-600 text-white hover:bg-indigo-700 py-2 rounded-lg text-xs font-bold transition-colors flex items-center justify-center gap-2">
                                <i class="fa-solid fa-download"></i> Unduh Foto Ber-Watermark Resmi
                            </button>
                        </div>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <!-- PRINT VIEW AREA -->
    <div id="printArea" class="hidden">
        <!-- Professional Official Header Document Form FR/PRJ/004 -->
        <div class="print-header">
            <table style="width: 100%; border-bottom: 2px solid #000; margin: 0;">
                <tr>
                    <td rowspan="2" style="width: 25%; text-align: center; vertical-align: middle; font-weight: bold; font-size: 14pt;">
                        PRESTIGE VISION
                    </td>
                    <td rowspan="2" style="width: 45%; text-align: center; vertical-align: middle; font-weight: bold; font-size: 15pt; letter-spacing: 1px;">
                        LAPORAN HARIAN<br><span style="font-size: 11pt; font-style: italic; font-weight: normal;">(Daily Report)</span>
                    </td>
                    <td style="width: 13%; font-size: 8pt; padding: 2px 5px !important;">KODE DOKUMEN</td>
                    <td style="width: 17%; font-size: 8pt; padding: 2px 5px !important;">: FR/PRJ/004</td>
                </tr>
                <tr>
                    <td style="font-size: 8pt; padding: 2px 5px !important;">MULAI BERLAKU</td>
                    <td style="font-size: 8pt; padding: 2px 5px !important;">: 2025</td>
                </tr>
                <tr>
                    <td style="font-size: 8pt; text-align: center; padding: 2px !important;">PRESTIGE VISION BUILDER</td>
                    <td style="font-size: 8pt; text-align: center; font-style: italic; padding: 2px !important;">Manajemen Proyek Konstruksi Terpadu</td>
                    <td style="font-size: 8pt; padding: 2px 5px !important;">REVISI / TGL REV</td>
                    <td style="font-size: 8pt; padding: 2px 5px !important;">: 00 / -</td>
                </tr>
            </table>
        </div>

        <!-- Project Meta Information Block -->
        <table style="width: 100%; margin-bottom: 15px;">
            <tr>
