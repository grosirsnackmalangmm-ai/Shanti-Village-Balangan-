        // Feature 3: Core Graphic Canvas Watermark Stamper Engine
        let sourceUploadedImageObject = null;
        function processProjectPhoto(event) {
            const file = event.target.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = function(e) {
                sourceUploadedImageObject = new Image();
                sourceUploadedImageObject.onload = function() {
                    document.getElementById('canvas-placeholder').classList.add('hidden');
                    document.getElementById('watermarkCanvas').classList.remove('hidden');
                    document.getElementById('download-doc-area').classList.remove('hidden');
                    redrawWatermarkCanvas();
                };
                sourceUploadedImageObject.src = e.target.result;
            };
            reader.readAsDataURL(file);
        }

        function redrawWatermarkCanvas() {
            if(!sourceUploadedImageObject) return;

            const canvas = document.getElementById('watermarkCanvas');
            const ctx = canvas.getContext('2d');

            // Enforce resolution parameters to preserve industrial clarity quality
            canvas.width = sourceUploadedImageObject.naturalWidth || 1024;
            canvas.height = sourceUploadedImageObject.naturalHeight || 768;

            // Draw base structural image layout layer
            ctx.drawImage(sourceUploadedImageObject, 0, 0, canvas.width, canvas.height);

            // Create solid professional dark dark translucent HUD container at bottom edge area
            const overlayHeight = canvas.height * 0.16;
            ctx.fillStyle = "rgba(15, 23, 42, 0.75)"; // Tailwind Slate 900 tint alpha
            ctx.fillRect(0, canvas.height - overlayHeight, canvas.width, overlayHeight);

            // Inject Metadata typography properties
            const now = new Date();
            const timeStr = now.toTimeString().split(' ')[0];
            const dateStr = formatDateIndo(now.toISOString().split('T')[0]);
            const locationText = document.getElementById('doc-location-name').value || "Shanti Villages Construction Site";
            
            let gpsStr = "GPS Coord: -8.79421, 115.12354 (Balangan Headland Default)";
            if(globalCoordinates) {
                gpsStr = `GPS Coord: ${globalCoordinates.lat}, ${globalCoordinates.lon}`;
            }

            const fontSize = Math.max(14, Math.floor(canvas.height * 0.025));
            ctx.font = `bold ${fontSize}px 'Arial', sans-serif`;
            
            // Text Color Accent setup
            ctx.fillStyle = "#fbbf24"; // Amber gold highlight text accent color
            ctx.fillText(`PROGESS DOKUMEN: ${locationText.toUpperCase()}`, 25, canvas.height - overlayHeight + (fontSize * 1.4));

            ctx.fillStyle = "#ffffff";
            ctx.font = `${fontSize * 0.85}px 'Arial', sans-serif`;
            ctx.fillText(`Waktu Pengambilan : ${dateStr} | Jam ${timeStr} WITA`, 25, canvas.height - overlayHeight + (fontSize * 2.8));
            ctx.fillText(`Sistem Validasi    : ${gpsStr} | Verified Static Upload`, 25, canvas.height - overlayHeight + (fontSize * 4.0));

            // Generate optimized Google Drive standard management clean filename string mapping
            const cleanLoc = locationText.replace(/[^a-zA-Z0-9]/g, '_');
            const fileStamp = now.getFullYear() + 
                              String(now.getMonth()+1).padStart(2,'0') + 
                              String(now.getDate()).padStart(2,'0') + "_" + 
                              timeStr.replace(/:/g,'');
            const targetFilename = `${fileStamp}_SHANTI_${cleanLoc.toUpperCase()}.jpg`;
            
            document.getElementById('generated-filename-label').innerText = `Filename: ${targetFilename}`;
            document.getElementById('generated-filename-label').dataset.filename = targetFilename;
        }

        // Trigger safe storage binary download payload stream
        function downloadStampedPhoto() {
            const canvas = document.getElementById('watermarkCanvas');
            const filename = document.getElementById('generated-filename-label').dataset.filename || 'DOKUMEN_PROYEK.jpg';
            
            const link = document.createElement('a');
            link.download = filename;
            link.href = canvas.toDataURL('image/jpeg', 0.9);
            link.click();
        }

        // GENERAL REUSABLE CONTEXT HELPERS
        function formatDateIndo(dateString) {
            if(!dateString) return '';
            const months = ['Januari', 'Februari', 'Maret', 'April', 'Mei', 'Juni', 'Juli', 'Agustus', 'September', 'Oktober', 'November', 'Desember'];
            const parts = dateString.split('-');
            if(parts.length !== 3) return dateString;
            return `${parseInt(parts[2])} ${months[parseInt(parts[1]) - 1]} ${parts[0]}`;
        }

        function copyToClipboard(text) {
            const dummy = document.createElement("textarea");
            document.body.appendChild(dummy);
            dummy.value = text;
            dummy.select();
            document.execCommand("copy");
            document.body.removeChild(dummy);
        }

        // Trigger dynamic state load initialization lifecycle on boot window event bind
        window.onload = function() {
            renderPORecordsList();
            
            // Sync form title dynamically if user inputs custom naming patterns inside blocks
            document.getElementById('doc-location-name').addEventListener('input', () => {
                if(sourceUploadedImageObject) redrawWatermarkCanvas();
            });
        };
    </script>
</body>
</html>
