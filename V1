        // Feature 2: Save Purchase Order Record into persistent state storage engine (LocalStorage)
        function savePurchaseOrder() {
            const project = document.getElementById('po-project').value;
            const date = document.getElementById('po-date').value;
            const code = document.getElementById('po-code').value;
            const title = document.getElementById('po-title').value;
            const items = document.getElementById('po-items').value;

            if(!code || !title) {
                alert('Mohon lengkapi kode PO beserta detail deskripsi item pengadaan barang!');
                return;
            }

            const newPO = { project, date, code, title, items, timestamp: new Date().getTime() };
            let savedList = JSON.parse(localStorage.getItem('shanti_po_records') || '[]');
